<Page
    x:Class="Stiche_zaubern.NetworkConnectPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Stiche_zaubern"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SystemColorHighlightBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="txtbox_playername" x:Uid="PlayerName" Margin="0,0,0,10" Width="200"/>
            <TextBox x:Name="txtbox_ip" x:Uid="HostIP" Text="192.168.178." Margin="0,0,0,10" Width="200"/>
            <TextBox x:Name="txtbox_port" x:Uid="HostPort" Text="5000" Width="200"/>
            <TextBlock x:Name="StatusText" x:Uid="ConnectionStatus" Width="200"/>

            <Button x:Name="StartButton" x:Uid="Connect" Click="StartButton_Click"
                    Style="{StaticResource XboxButtonStyle}" Width="200"
                    Grid.Row="5" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>

        <Button x:Name="BackButton" x:Uid="Back" Click="BackButton_Click"
                Style="{StaticResource XboxButtonStyle}" VerticalAlignment="Top" Margin="10"/>
    </Grid>
</Page>
