<Page
    x:Class="Stiche_zaubern.NetworkHostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Stiche_zaubern"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SystemColorHighlightBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBox x:Name="txtbox_playername" x:Uid="PlayerName" Margin="0,0,0,10" Width="200"/>
            <TextBlock x:Name="TextIP" x:Uid="HostIP" Width="200"/>
            <TextBlock x:Name="TextPort" x:Uid="HostPort" Width="200"/>
            <TextBlock x:Name="StatusText" x:Uid="HostStatus" Width="200"/>

            <Grid Width="350">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Spieler 2 -->
                <ComboBox x:Name="combo_player2" x:Uid="Player2Combo" SelectedIndex="0" Width="150" Grid.Row="0" Grid.Column="0">
                    <ComboBoxItem x:Name="Remote2" x:Uid="RemoteOption" />
                </ComboBox>
                <TextBlock x:Name="txt_status2" x:Uid="Player2Status" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>

                <!-- Spieler 3 -->
                <ComboBox x:Name="combo_player3" x:Uid="Player3Combo" SelectedIndex="0" Width="150" Grid.Row="1" Grid.Column="0" SelectionChanged="combo_player3_SelectionChanged">
                    <ComboBoxItem x:Name="Remote3" x:Uid="RemoteOption" />
                    <ComboBoxItem x:Uid="ComputerOption" />
                </ComboBox>
                <TextBlock x:Name="txt_status3" x:Uid="Player3Status" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>

                <!-- Spieler 4 -->
                <ComboBox x:Name="combo_player4" x:Uid="Player4Combo" SelectedIndex="0" Width="150" Grid.Row="2" Grid.Column="0" SelectionChanged="combo_player4_SelectionChanged">
                    <ComboBoxItem x:Name="Remote4" x:Uid="RemoteOption" />
                    <ComboBoxItem x:Uid="ComputerOption" />
                    <ComboBoxItem x:Name="Closed4" x:Uid="ClosedOption" />
                </ComboBox>
                <TextBlock x:Name="txt_status4" x:Uid="Player4Status" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>

                <!-- Spieler 5 -->
                <ComboBox x:Name="combo_player5" x:Uid="Player5Combo" SelectedIndex="0" Width="150" Grid.Row="3" Grid.Column="0" SelectionChanged="combo_player5_SelectionChanged">
                    <ComboBoxItem x:Name="Remote5" x:Uid="RemoteOption" />
                    <ComboBoxItem x:Uid="ComputerOption" />
                    <ComboBoxItem x:Name="Closed5" x:Uid="ClosedOption" />
                </ComboBox>
                <TextBlock x:Name="txt_status5" x:Uid="Player5Status" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"/>

                <!-- Spieler 6 -->
                <ComboBox x:Name="combo_player6" x:Uid="Player6Combo" SelectedIndex="0" Width="150" Grid.Row="4" Grid.Column="0" SelectionChanged="combo_player6_SelectionChanged">
                    <ComboBoxItem x:Name="Remote6" x:Uid="RemoteOption" />
                    <ComboBoxItem x:Uid="ComputerOption" />
                    <ComboBoxItem x:Name="Closed6" x:Uid="ClosedOption" />
                </ComboBox>
                <TextBlock x:Name="txt_status6" x:Uid="Player6Status" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center"/>

                <!-- Start-Button -->
                <Button x:Name="StartButton" x:Uid="Start" Click="StartButton_Click"
                        Style="{StaticResource XboxButtonStyle}" Width="200" IsEnabled="False"
                        Grid.Row="5" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </Grid>
        </StackPanel>

        <Button x:Name="BackButton" x:Uid="Back" Click="BackButton_Click"
                Style="{StaticResource XboxButtonStyle}" VerticalAlignment="Top" Margin="10"/>
    </Grid>
</Page>
