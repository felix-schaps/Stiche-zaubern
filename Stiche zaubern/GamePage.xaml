<Page
    x:Class="Stiche_zaubern.GamePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Stiche_zaubern"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Viewbox>
        <Grid>
            <Grid Background="{ThemeResource SystemControlBackgroundAccentBrush}">

                <!-- Oben sehr schmal quer über den oberen Bildschirmbereich -->
                <Grid x:Name="grid_menu" Background="LightBlue" Margin="0,-131,0,31">
                    <TextBlock TextWrapping="Wrap" Text="" VerticalAlignment="Top" HorizontalAlignment="Center" TextAlignment="Center" Width="1048" Margin="10,10,0,0" Height="33"/>
                </Grid>

                <!-- Links oben -->
                <Grid x:Name="grid_player3" Background="LightGreen" Margin="0,-77,635,286">
                    <TextBlock x:Name="txt_player3" HorizontalAlignment="Left" Margin="0,10,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="184" Height="176" FontSize="14"/>
                    <!-- Hier können Sie Inhalte für das linke obere Grid platzieren -->
                </Grid>

                <!-- Über dem in der Mitte -->
                <Grid x:Name="grid_player4" Background="LightGreen" Margin="315,-77,315,286">
                    <TextBlock x:Name="txt_player4" HorizontalAlignment="Center" Margin="52,10,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="300" Height="107" FontSize="14"/>
                    <!-- Hier können Sie Inhalte für das rechte obere Grid platzieren -->
                </Grid>

                <!-- Rechts oben -->
                <Grid x:Name="grid_player5" Background="LightGreen" Margin="635,-77,0,286">
                    <TextBlock x:Name="txt_player5" HorizontalAlignment="Right" Margin="198,0,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="188" Height="167" FontSize="14"/>
                    <!-- Hier können Sie Inhalte für das obere Grid in der Mitte platzieren -->
                </Grid>



                <!-- Quadratisch in der Mitte -->
                <Grid x:Name="grid_game_board" VerticalAlignment="Top" HorizontalAlignment="Center" Width="470" Height="292" Background="LightGreen" Margin="0,117,0,0">
                    <Image x:Name="pic_trumpfkarte" HorizontalAlignment="Center" Height="85" Margin="0,84,0,0" VerticalAlignment="Top" Width="52" Source="/Assets/Unknown.jpg"/>
                    <ComboBox x:Name="combo_raten" x:Uid="NumberOfTricks" Margin="0,10,0,0" Width="200" HorizontalAlignment="Center"/>
                    <Button x:Name="button_raten_fertig" x:Uid="Ready" Style="{StaticResource XboxButtonStyle}" Width="200" Margin="0,183,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Click="button_raten_fertig_Click"/>
                    <!--<Image x:Name="stich_active_player" HorizontalAlignment="Center" Height="85" Margin="0,168,0,0" VerticalAlignment="Top" Width="52" Source="/Assets/Unknown.jpg" Visibility="Collapsed"/>
                <Image x:Name="stich_player2" HorizontalAlignment="Left" Height="85" Margin="10,99,0,0" VerticalAlignment="Top" Width="52" Source="/Assets/Unknown.jpg" Visibility="Collapsed"/>
                <Image x:Name="stich_player3" HorizontalAlignment="Left" Height="85" VerticalAlignment="Top" Width="52" Source="/Assets/Unknown.jpg" Margin="10,10,0,0" Visibility="Collapsed"/>
                <Image x:Name="stich_player4" HorizontalAlignment="Center" Height="85" Margin="0,-4,0,0" VerticalAlignment="Top" Width="52" Source="/Assets/Unknown.jpg" Visibility="Collapsed"/>
                <Image x:Name="stich_player5" HorizontalAlignment="Left" Height="85" Margin="398,10,0,0" VerticalAlignment="Top" Width="52" Source="/Assets/Unknown.jpg" Visibility="Collapsed"/>
                <Image x:Name="stich_player6" HorizontalAlignment="Left" Height="85" Margin="398,99,0,0" VerticalAlignment="Top" Width="52" Source="/Assets/Unknown.jpg" Visibility="Collapsed"/>-->
                    <!-- Hier können Sie Inhalte für das mittlere quadratische Grid platzieren -->
                </Grid>
                <!-- Links unten -->
                <Grid x:Name="grid_player2" Background="LightGreen" Margin="0,117,710,-3">
                    <TextBlock x:Name="txt_player2" HorizontalAlignment="Left" Margin="10,67,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="172" Width="135" FontSize="14"/>
                    <!-- Hier können Sie Inhalte für das linke untere Grid platzieren -->
                </Grid>
                <!-- Rechts unten -->
                <Grid x:Name="grid_player6" Background="LightGreen" Margin="767,114,1,0">
                    <TextBlock x:Name="txt_player6" HorizontalAlignment="Right" Margin="160,68,0,87" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Height="172" Width="136" FontSize="14"/>
                    <!-- Hier können Sie Inhalte für das rechte untere Grid platzieren -->
                </Grid>

                <!-- Unter dem in der Mitte -->
                <!-- grid_active_player: klare Spalten, ScrollViewer in Spalte 0, txt_player1 in Spalte 1 -->
                <Grid x:Name="grid_active_player" Background="LightYellow" Margin="0,409,0,-127">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <!-- Platz für ScrollViewer -->
                        <ColumnDefinition Width="200" />
                        <!-- feste Breite für txt_player1 -->
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                  HorizontalScrollBarVisibility="Auto"
                  Margin="3,0,8,0">
                        <StackPanel x:Name="panel_active_player" Orientation="Horizontal"/>
                    </ScrollViewer>

                    <TextBlock x:Name="txt_player1"
               Grid.Column="1"
               HorizontalAlignment="Left"
               Margin="8,10,0,0"
               TextWrapping="Wrap"
               Text=""
               VerticalAlignment="Top"
               Height="100"
               Width="180"
               FontSize="14"/>
                </Grid>

                <Button x:Uid="Exit" Click="BackButton_Click" Style="{StaticResource XboxButtonStyle}" VerticalAlignment="Top" Margin="0,-131,0,0" RenderTransformOrigin="0.479,-0.951"/>

            </Grid>
            <Canvas x:Name="AnimationCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False" Background="Transparent"/>
        </Grid>
    </Viewbox>
</Page>
